{
  "name": "memory_upsert",
  "description": "Store an exchange vector + text in the lcdata springg memory index. Use id=unix timestamp, metadata=exchange text.",
  "type": "vector",
  "operation": "upsert",
  "index": "lcdata",
  "input": {
    "id": {
      "type": "string",
      "required": true
    },
    "vector": {
      "type": "array",
      "required": true
    },
    "metadata": {
      "type": "string",
      "required": false
    }
  },
  "output": {
    "ok": { "type": "boolean" }
  }
}
