{
  "name": "web_search",
  "description": "Searches the web using Brave Search API and returns top results with title, URL, and description",
  "type": "search",
  "search_provider": "brave",
  "search_count": 10,
  "input": {
    "query": { "type": "string", "required": true }
  },
  "output": {
    "results": { "type": "array", "description": "Array of {title, url, description}" },
